{
  "buildCommand": "cd gscs-frontend && npm install && npm run build",
  "outputDirectory": "gscs-frontend/dist",
  "installCommand": "echo 'install handled in build'",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|favicon\\.ico|placeholder\\.svg|robots\\.txt|pod-server).*)",
      "destination": "/index.html"
    }
  ]
}